---
import Layout from "../components/Layout.astro";
import SearchPanel from "../components/SearchPanel.astro";
import { formatDate, getAllPosts, getReadingTimeText } from "../lib/blog";

const posts = await getAllPosts();
const featuredPost = posts[0];
---

<Layout
  title="Systems Editorials for Engineers"
  description="Bias Layer is a technical editorial publication covering AI systems, inference economics, safety architecture, and the engineering reality under the hype."
  posts={posts}
>
  <section class="mx-auto max-w-reading">
    {featuredPost && (
      <a
        href={`/blog/${featuredPost.slug}/`}
        class="mt-8 block rounded-[2rem] border border-accent-500/20 bg-accent-500/[0.08] p-6 transition hover:border-accent-500/40 hover:bg-accent-500/[0.12] sm:p-8"
      >
        <p class="font-heading text-sm uppercase tracking-[0.26em] text-accent-300">Latest Post</p>
        <h2 class="mt-3 font-heading text-3xl font-semibold text-white light:text-light-900">{featuredPost.data.title}</h2>
        <p class="mt-4 text-lg leading-8 text-ink-200 light:text-light-600">{featuredPost.data.excerpt}</p>
        <div class="mt-5 flex flex-wrap gap-3 text-xs uppercase tracking-[0.18em] text-ink-400 light:text-light-500">
          <span>{formatDate(featuredPost.data.date)}</span>
          <span>{getReadingTimeText(featuredPost)}</span>
          <span>{featuredPost.data.tags.join(" · ")}</span>
        </div>
      </a>
    )}

    <div class="mt-10">
      <SearchPanel posts={posts} />
    </div>

    <section class="mt-10 space-y-4">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}/`}
          class="block rounded-[1.75rem] border border-white/10 bg-white/[0.02] p-5 transition hover:border-white/20 hover:bg-white/[0.04] dark:border-white/10 dark:bg-white/[0.02] dark:hover:border-white/20 dark:hover:bg-white/[0.04] light:border-light-700/30 light:bg-white light:hover:border-light-700/50 light:hover:bg-light-50"
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="min-w-0">
              <h2 class="font-heading text-2xl font-semibold text-white light:text-light-900">{post.data.title}</h2>
              <p class="mt-3 text-base leading-8 text-ink-300 light:text-light-600">{post.data.excerpt}</p>
            </div>
            <div class="shrink-0 text-xs uppercase tracking-[0.2em] text-ink-500 light:text-light-400">
              {formatDate(post.data.date)}
            </div>
          </div>
          <div class="mt-4 flex flex-wrap gap-3 text-xs uppercase tracking-[0.18em] text-ink-500 light:text-light-400">
            <span>{getReadingTimeText(post)}</span>
            <span>{post.data.tags.join(" · ")}</span>
          </div>
        </a>
      ))}
    </section>
  </section>
</Layout>
