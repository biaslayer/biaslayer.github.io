---
import type { BlogPost } from "../lib/blog";
import { formatDate, groupPostsByYear } from "../lib/blog";

interface Props {
  posts: BlogPost[];
  activeSlug?: string;
  mobile?: boolean;
}

const { posts, activeSlug, mobile = false } = Astro.props;
const groupedPosts = Object.entries(groupPostsByYear(posts));
---

<aside
  id={mobile ? "site-sidebar" : undefined}
  class:list={[
    "w-[18rem] border-r border-white/10 bg-ink-950/95 px-4 py-6 backdrop-blur dark:border-white/10 dark:bg-ink-950/95 light:border-gray-200 light:bg-white",
    mobile
      ? "fixed inset-y-0 left-0 z-50 -translate-x-full transition duration-300 lg:hidden"
      : "sticky top-16 z-20 h-[calc(100vh-4rem)] overflow-y-auto"
  ]}
>
  <div class="space-y-6 pt-12 lg:pt-0">
    <nav aria-label="Blog posts" class="space-y-4">
      {groupedPosts.map(([year, yearPosts]) => (
        <details open={year === String(new Date().getFullYear())} class="group rounded-2xl border border-white/5 bg-white/[0.02] dark:border-white/5 dark:bg-white/[0.02] light:border-gray-200 light:bg-gray-50">
          <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 font-heading text-sm font-medium text-ink-100 dark:text-ink-100 light:text-gray-700">
            <span>{year}</span>
            <span class="text-xs text-ink-500 transition group-open:rotate-45 dark:text-ink-500 light:text-gray-400">+</span>
          </summary>
          <div class="space-y-1 px-2 pb-2">
            {yearPosts.map((post) => {
              const isActive = activeSlug === post.slug;
              return (
                <a
                  href={`/blog/${post.slug}/`}
                  class:list={[
                    "block rounded-xl px-3 py-3 transition",
                    isActive
                      ? "border border-accent-500/30 bg-accent-500/10 text-white"
                      : "border border-transparent text-ink-300 hover:border-white/10 hover:bg-white/5 hover:text-white dark:border-transparent dark:text-ink-300 dark:hover:border-white/10 dark:hover:bg-white/5 dark:hover:text-white light:border-transparent light:text-gray-600 light:hover:border-gray-200 light:hover:bg-gray-100 light:hover:text-gray-900"
                  ]}
                  aria-current={isActive ? "page" : undefined}
                >
                  <span class="block font-heading text-sm font-medium leading-5 dark:text-white light:text-gray-700">{post.data.title}</span>
                  <span class="mt-1 block text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-500 light:text-gray-400">
                    {formatDate(post.data.date)}
                  </span>
                </a>
              );
            })}
          </div>
        </details>
      ))}
    </nav>
  </div>
</aside>
